{
  "name": "webapp",
  "version": "0.1.0",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron-dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.upfeedth.affiliatesystem",
    "productName": "FB Affiliate System",
    "publish": {
      "provider": "github"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/standalone/**/*",
      "launcher-gui.html",
      "electron-main.js",
      "upfeed_logo.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "upfeed_logo.png"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  }
}
