{
  "manifest_version": 3,
  "name": "FB Affiliate System Extractor",
  "version": "1.0",
  "description": "ดึงโพสต์จาก Facebook Page เข้าสู่ระบบจัดการคิวงาน Affiliate",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["*://*.facebook.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["content.js"]
    }
  ]
}
