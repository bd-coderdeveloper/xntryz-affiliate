{
  "manifest_version": 3,
  "name": "BD FB Affiliate Extension",
  "version": "1.4",
  "description": "BD FB Affiliate Extension",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.facebook.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}